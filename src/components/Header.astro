---
import { menuMain } from "~/data/menus.js";
import LogoContainer from "~/components//LogoContainer.astro";
import SocialMediaIcons from "./SocialMediaIcons.astro";

const rmTrailingSlash = (path: string): string => {
  return path.endsWith("/") && path.length > 1 
    ? path.slice(0, path.length - 1) 
    : path;
}

const pathname = rmTrailingSlash(Astro.url.pathname);
---

<header x-data="{ open: false, scrolled: false }" @keydown.window.escape="open = false" x-init="scrolled = window.scrollY > 80; window.addEventListener('scroll', () => { scrolled = window.scrollY > 80 })">
	<div>
		<div id="header-wrapper" class="fixed top-0 z-40 inset-x-0 w-full">
			<div>
				<div class="max-lg:px-4 backdrop-blur-xl py-4 px-6 transition-colors duration-300"
					:class="scrolled ? 'bg-gray-800/60 border-b border-gray-700/50' : 'bg-violet-950/20 border-b border-violet-400/10'">
					<nav class="grid grid-cols-[auto_1fr_auto] items-center gap-4" aria-label="Global">
						<a href="/">
							<LogoContainer />
						</a>
						<div class="max-lg:hidden flex gap-x-6 xl:gap-x-10 justify-center items-center flex-wrap">
							{
								menuMain.map((item) => (
									<a
										href={item.url}
										class={`transition text-sm font-medium tracking-wide whitespace-nowrap ${pathname === item.url ? "font-bold" : ""}`}
										:class="scrolled ? 'text-gray-300 hover:text-white' : 'text-violet-200/60 hover:text-violet-100'"
									>
										{item.name}
									</a>
								))
							}
						</div>
						<div class="flex items-center justify-end gap-x-4">
							<a href="tel:0400123123" class="max-xl:hidden text-sm font-medium transition whitespace-nowrap"
								:class="scrolled ? 'text-gray-400 hover:text-white' : 'text-violet-200/50 hover:text-violet-100'">0400 123 123</a>
							<a href="/#contact" class="max-xl:hidden text-sm font-semibold px-4 py-2 border transition whitespace-nowrap"
								:class="scrolled ? 'border-gray-500 text-gray-200 hover:bg-gray-700' : 'border-violet-400/35 text-violet-200 hover:bg-violet-500/20 hover:border-violet-400/60'">
								Get in touch
							</a>
							<div class="flex lg:hidden">
								<button
									type="button"
									class="-m-2.5 inline-flex items-center justify-center p-2.5"
									@click="open = true"
								>
									<span class="sr-only">Open main menu</span>
									<svg
										class="size-6 transition-colors duration-300"
										:class="scrolled ? 'text-gray-300' : 'text-violet-300/60'"
										fill="none"
										viewBox="0 0 24 24"
										stroke-width="1.5"
										stroke="currentColor"
										aria-hidden="true"
										data-slot="icon"
									>
										<path
											stroke-linecap="round"
											stroke-linejoin="round"
											d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
									</svg>
								</button>
							</div>
						</div>
					</nav>
				</div>
			</div>
		</div>
		<div class="lg:hidden" x-ref="dialog" x-show="open" x-cloak aria-modal="true">
			<div
				class="fixed inset-0 z-50 w-full overflow-y-auto bg-violet-950/90 backdrop-blur-xl px-12 py-8"
				x-show="open"
				x-transition:enter="transition ease-out"
				x-transition:enter-start="opacity-0"
				x-transition:enter-end="opacity-100"
				x-transition:leave="transition ease-in"
				x-transition:leave-start="opacity-100"
				x-transition:leave-end="opacity-0"
				x-cloak
			>
				<div class="flex items-center justify-between">
					<LogoContainer />
					<button type="button" class="-m-2.5 p-2.5 text-gray-400 hover:text-white transition" @click="open = false">
						<span class="sr-only">Close menu</span>
						<svg
							class="size-8"
							fill="none"
							viewBox="0 0 24 24"
							stroke-width="2"
							stroke="currentColor"
							aria-hidden="true"
							data-slot="icon"
						>
							<path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"></path>
						</svg>
					</button>
				</div>
				<div class="mt-6 flow-root">
					<div class="-my-6 divide-y divide-gray-500/10">
						<div class="space-y-2 py-6 mt-16">
							{
								menuMain.map((item) => (
									<a
										x-on:click="open = false"
										href={item.url}
										class={`block py-2 text-center font-medium text-2xl tracking-wide text-violet-200/60 hover:text-violet-100 transition ${pathname === item.url ? "!text-violet-200" : ""}`}
									>
										{item.name}
									</a>
								))
							}
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</header>

<script>
	document.addEventListener("astro:page-load", () => {
		const headerWrapper = document.getElementById("header-wrapper")!;
		const setHeaderHeight = () => {
			document.documentElement.style.setProperty("--header-height", `${headerWrapper.offsetHeight}px`);
		};
		setHeaderHeight();
		window.addEventListener("resize", setHeaderHeight);
	});
</script>
