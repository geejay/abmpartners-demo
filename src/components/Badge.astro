---
const { color = "teal", title = "" }: BadgeProps = Astro.props;

interface BadgeProps {
	color?: "red" | "teal";
	title?: string;
}

const colors = {
	fuchsia: "theme-badge",
	teal: "theme-badge",
	white: "bg-white",
};
---

<span class={`inline-flex not-prose items-center mb-4 rounded-full px-3 py-1 text-base font-semibold ${colors[color]}`}
	>{title}</span
>
