---
const { title = "", link } = Astro.props;
---

<div class="flex flex-col lg:flex-row items-center gap-8 lg:justify-evenly max-w-4xl w-full mx-auto">
	<h2 class="text-white text-center">{title}</h2>

	{
		link && (
			<a class="shrink-0 inline-flex items-center gap-3 bg-white text-gray-900 font-bold tracking-widest uppercase text-sm px-12 py-5 shadow-lg hover:bg-gray-100 active:scale-95 transition duration-200" href={link.url}>
				{link.title} &rarr;
			</a>
		)
	}
</div>
