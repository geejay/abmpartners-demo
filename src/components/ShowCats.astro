---
import { getCollection } from "astro:content";
import CardCat from "./CardCat.astro";
const { cats = [] } = Astro.props;
const allCats = await getCollection("cats");
const catEntries = cats.map((id: string) => allCats.find((c) => c.id === id)).filter(Boolean);
---

<div>
	<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-16 xl:gap-24">
		{catEntries.map((cat) => <CardCat cat={cat} />)}
	</div>
</div>
