---
export const prerender = false;

import { env } from 'cloudflare:workers';
import Layout from "~/layouts/Layout.astro";
import Section from "~/components/Section.astro";
import Container from "~/components/Container.astro";

const { slug } = Astro.params;

const DB = (env as any).DB as D1Database | undefined;

let event: { name: string; description: string | null; date: string | null; location: string | null } | null = null;

if (DB) {
    const row = await DB.prepare(
        "SELECT name, description, date, location FROM events WHERE slug = ? AND active = 1 LIMIT 1"
    ).bind(slug).first<{ name: string; description: string | null; date: string | null; location: string | null }>();
    event = row ?? null;
}

if (!event) {
    return new Response(null, { status: 404 });
}
---

<Layout
    title={`Register — ${event.name}`}
    pageTitle={`Register — ${event.name}`}
    description={event.description ?? `Register your details for ${event.name}.`}
>
    <Section>
        <Container>
            <div class="max-w-2xl mx-auto py-16">
                <h1 class="text-3xl font-black theme-heading mb-2">{event.name}</h1>
                {event.description && <p class="text-gray-600 mb-2">{event.description}</p>}
                {(event.date || event.location) && (
                    <p class="text-sm text-gray-400 mb-8">
                        {event.date}{event.date && event.location ? " · " : ""}{event.location}
                    </p>
                )}
                <p class="text-gray-500 mb-10 text-sm">Fill in your details below to register your interest.</p>

                <form
                    action="/api/register"
                    method="POST"
                    x-data="{
                        status: 'idle',
                        async submit(e) {
                            e.preventDefault();
                            this.status = 'loading';
                            const form = e.target;
                            const res = await fetch(form.action, { method: 'POST', body: new FormData(form) });
                            const json = await res.json();
                            if (json.success) {
                                this.status = 'success';
                                form.reset();
                            } else {
                                this.status = 'error';
                            }
                        }
                    }"
                    @submit="submit"
                >
                    <input type="hidden" name="event_slug" value={slug} />

                    <div class="flex flex-col gap-8">
                        <div class="grid grid-cols-1 gap-8 sm:grid-cols-2">
                            <div>
                                <label for="first_name" class="block text-sm font-semibold theme-heading mb-2">First Name <span class="text-red-500">*</span></label>
                                <input type="text" name="first_name" id="first_name" required class="contact-input" />
                            </div>
                            <div>
                                <label for="last_name" class="block text-sm font-semibold theme-heading mb-2">Last Name <span class="text-red-500">*</span></label>
                                <input type="text" name="last_name" id="last_name" required class="contact-input" />
                            </div>
                        </div>

                        <div class="grid grid-cols-1 gap-8 sm:grid-cols-2">
                            <div>
                                <label for="company" class="block text-sm font-semibold theme-heading mb-2">Company <span class="text-red-500">*</span></label>
                                <input type="text" name="company" id="company" required class="contact-input" />
                            </div>
                            <div>
                                <label for="position" class="block text-sm font-semibold theme-heading mb-2">Position / Title <span class="text-red-500">*</span></label>
                                <input type="text" name="position" id="position" required class="contact-input" />
                            </div>
                        </div>

                        <div class="grid grid-cols-1 gap-8 sm:grid-cols-2">
                            <div>
                                <label for="email" class="block text-sm font-semibold theme-heading mb-2">Email Address <span class="text-red-500">*</span></label>
                                <input type="email" name="email" id="email" placeholder="you@example.com" required class="contact-input" />
                            </div>
                            <div>
                                <label for="phone" class="block text-sm font-semibold theme-heading mb-2">Phone Number</label>
                                <input type="tel" name="phone" id="phone" class="contact-input" />
                            </div>
                        </div>

                        <div class="flex flex-col gap-4">
                            <button
                                type="submit"
                                class="button button-teal group !px-8 w-full sm:w-auto"
                                :disabled="status === 'loading'"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke-width="1.5"
                                    stroke="currentColor"
                                    class="size-5 -rotate-45 -mt-1 inline-block mr-1 group-hover:rotate-0 transition duration-300"
                                >
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5" />
                                </svg>
                                <span x-text="status === 'loading' ? 'Submitting…' : 'Register'">Register</span>
                            </button>

                            <p x-show="status === 'success'" x-cloak class="text-green-600 font-medium">
                                Thanks for registering! We'll be in touch soon.
                            </p>
                            <p x-show="status === 'error'" x-cloak class="text-red-600 font-medium">
                                Something went wrong. Please try again or contact us directly.
                            </p>
                        </div>
                    </div>
                </form>
            </div>
        </Container>
    </Section>
</Layout>

<style>
    .contact-input {
        display: block;
        width: 100%;
        border-radius: 0.375rem;
        border-width: 1px;
        border-color: var(--theme-grid-divider);
        padding: 0.5rem 0.75rem;
        font-size: 0.875rem;
        outline: none;
        transition: border-color 0.15s, box-shadow 0.15s;
    }
    .contact-input:focus {
        --tw-ring-color: var(--theme-badge-ring);
        border-color: var(--theme-badge-ring);
        box-shadow: 0 0 0 2px var(--tw-ring-color, transparent);
    }
</style>
