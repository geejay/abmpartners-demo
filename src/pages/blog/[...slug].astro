---
export const prerender = true;

import Layout from "~/layouts/Layout.astro";
import Section from "~/components/Section.astro";
import Container from "~/components/Container.astro";
import Article from "~/components/Article.astro";
import HeadingBlog from "~/components/HeadingBlog.astro";
import { getCollection, render } from "astro:content";
import { getImage } from "astro:assets";

export async function getStaticPaths() {
	const posts = await getCollection("blog");
	return posts.map((post) => ({
		params: { slug: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await render(post);
const ogImage = await getImage({ src: post.data.image, width: 1200, height: 630, format: "jpeg" });
---

<Layout
	title={post.data.title}
	pageTitle={`${post.data.title} — ABM Partners`}
	description={post.data.excerpt ?? post.data.title}
	ogImage={ogImage.src}
>
	<Section>
		<Container>
			<Article contain>
				<HeadingBlog
					title={post.data.title}
					image={post.data.image}
					imageAlt={post.data.imageAlt}
					excerpt={post.data.excerpt}
					id={post.id}
				/>
				<Content />
			</Article>
		</Container>
	</Section>
</Layout>
