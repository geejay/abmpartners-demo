---
import { getCollection } from "astro:content";
import Layout from "~/layouts/Layout.astro";
import Section from "~/components/Section.astro";
import Container from "~/components/Container.astro";
import Heading from "~/components/Heading.astro";
import CardBlogPost from "~/components/CardBlogPost.astro";
const posts = await getCollection("blog");
---

<Layout>
	<Section>
		<Container>
			<Heading>
				<h1 slot="heading-title" class="h2 text-gray-500">Blog</h1>
				<p slot="heading-content">
					Stay up to date with event industry trends, planning insights, and highlights from events we've
					delivered for our clients across Australia.
				</p>
			</Heading>

			<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-16 xl:gap-24">
				{posts.map((post) => <CardBlogPost post={post} />)}
			</div>
		</Container>
	</Section>
</Layout>
